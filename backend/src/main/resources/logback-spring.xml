<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 로그 파일 저장 경로 (앱 실행 위치 기준 logs/ 디렉토리) -->
    <property name="LOG_PATH" value="logs"/>
    <property name="LOG_FILE" value="${LOG_PATH}/cali"/>

    <!-- 콘솔 출력: 개발 환경에서는 INFO 이상 출력 -->
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!--
        파일 롤링 정책
        - WARN 이상(WARN, ERROR)만 기록
        - 자정마다 날짜별로 롤링: cali.log → cali-2026-03-10.log
        - 하루 50MB 초과 시 인덱스 분할: cali-2026-03-10-1.log, cali-2026-03-10-2.log ...
        - 5일 이상 지난 파일은 자동 삭제
    -->
    <appender name="WarnErrorFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 현재 활성 파일 (오늘 로그) -->
        <file>${LOG_FILE}.log</file>

        <!-- WARN 미만(INFO, DEBUG)은 기록하지 않음 -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 롤링 후 파일명 패턴: 날짜 + 인덱스 -->
            <fileNamePattern>${LOG_FILE}-%d{yyyy-MM-dd}-%i.log</fileNamePattern>
            <!-- 단일 파일 최대 크기: 50MB 초과 시 인덱스 분할 -->
            <maxFileSize>50MB</maxFileSize>
            <!-- 보관 일수: 5일 -->
            <maxHistory>5</maxHistory>
            <!-- 전체 로그 최대 용량 상한선 (방어용) -->
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 프로젝트 패키지: DEBUG까지 캡처 (파일엔 WARN 이상만 기록됨) -->
    <logger name="com.bada.cali" level="DEBUG" additivity="false">
        <appender-ref ref="Console"/>
        <appender-ref ref="WarnErrorFile"/>
    </logger>

    <!-- 외부 라이브러리(Spring, Hibernate 등): WARN 이상만 -->
    <root level="WARN">
        <appender-ref ref="Console"/>
        <appender-ref ref="WarnErrorFile"/>
    </root>

</configuration>